SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend.up.railway.app
DATABASE_URL=postgresql://user:password@localhost:5432/lekscars
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://backend.up.railway.app
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
MEDIA_URL=/media/
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
# For production on Railway, Railway sets DATABASE_URL automatically
